CONTACT_TO_EMAIL=accesc625@gmail.com
NEXT_PUBLIC_SITE_URL=https://acces-canada.com

# Admin dashboard
ADMIN_PASSWORD=change-this-strong-admin-password
ADMIN_SESSION_SECRET=change-this-long-random-session-secret
# Optional. Keep unset on Vercel unless you need to override cookie behavior.
ADMIN_COOKIE_SECURE=true

# Client portal
CLIENT_SESSION_SECRET=change-this-long-random-client-session-secret
# Optional. Keep unset on Vercel unless you need to override cookie behavior.
CLIENT_COOKIE_SECURE=true
# Optional local-only fallback. Keep false or unset in production.
CLIENT_DEV_EMAIL_FALLBACK=false

# Supabase. Use the service role key only on the server/Vercel environment variables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_CONTACT_TABLE=contact_requests
SUPABASE_CLIENTS_TABLE=admin_clients
SUPABASE_DOCUMENTS_TABLE=admin_generated_documents
SUPABASE_CLIENT_LOGIN_CODES_TABLE=client_login_codes
SUPABASE_CLIENT_UPLOADS_TABLE=client_uploaded_documents
SUPABASE_CLIENT_DOCUMENTS_BUCKET=client-documents
SUPABASE_CLIENT_SIGNATURES_TABLE=client_document_signatures
SUPABASE_CLIENT_PAYMENTS_TABLE=client_payments
SUPABASE_APPOINTMENTS_TABLE=client_appointments

# Stripe payments. Use test keys locally and live keys only in Vercel production.
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Gmail SMTP.
# Use a Google App Password, not the normal Gmail account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_STARTTLS=false
SMTP_USER=accesc625@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM=accesc625@gmail.com
